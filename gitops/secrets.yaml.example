# Template only — do not apply. Generate with Docker, then create the secret via kubectl:
#
#   docker run --rm -v "$PWD:/out" influxdb:3-core \
#     influxdb3 create token --admin --offline --name admin \
#     --output-file /out/admin-token.json
#
#   kubectl -n influxdb create secret generic influxdb-admin-token \
#     --from-file=admin-token.json=admin-token.json
#
# Token string must start with apiv3_ (enforced by InfluxDB 3 Core).
#
apiVersion: v1
kind: Secret
metadata:
  name: influxdb-admin-token
  namespace: influxdb
type: Opaque
stringData:
  admin-token.json: |
    {"token":"apiv3_<GENERATE_OFFLINE>","name":"admin","description":"GitOps admin token"}
